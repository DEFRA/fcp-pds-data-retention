{
  "name": "fcp-pds-data-retention",
  "version": "1.1.0",
  "description": "Payment & Document Services shared data retention processing capabilities",
  "homepage": "https://github.com/DEFRA/fcp-pds-data-retention",
  "main": "app/index.js",
  "scripts": {
    "pretest": "npm run test:lint",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --coverage=false --onlyChanged --watch --runInBand",
    "test:lint": "eslint",
    "test:lint:fix": "eslint --fix",
    "test:debug": "node --inspect-brk=0.0.0.0 ./node_modules/jest/bin/jest.js --coverage=false --onlyChanged --watch --runInBand --no-cache",
    "start:watch": "nodemon --inspect=0.0.0.0 --ext js --legacy-watch app/index.js",
    "start:debug": "nodemon --inspect-brk=0.0.0.0 --ext js --legacy-watch app/index.js",
    "prepare": "node --eval \"const fs=require('fs'),cp=require('child_process');if(fs.existsSync('.git')&&!process.env.CI&&!process.env.TF_BUILD)cp.execSync('husky',{stdio:'inherit'})\""
  },
  "author": "Defra",
  "contributors": [
    "Sam Plackett samuel.plackett@atos.ai",
    "Leigh Godson leigh.godson@atos.ai",
    "Alistair Wishart alistair.wishart@atos.ai"
  ],
  "license": "OGL-UK-3.0",
  "dependencies": {
    "@azure/identity": "4.13.1",
    "@azure/monitor-opentelemetry": "1.18.2",
    "@azure/storage-blob": "12.31.0",
    "@hapi/boom": "10.0.1",
    "@hapi/hapi": "21.3.2",
    "csv-parser": "3.2.0",
    "ffc-database": "1.0.27",
    "ffc-messaging": "2.10.8",
    "ffc-pay-event-publisher": "1.2.7",
    "hapi-pino": "12.1.0",
    "joi": "18.2.1",
    "log-timestamp": "0.3.0",
    "unzipper": "0.12.3"
  },
  "devDependencies": {
    "blipp": "4.0.2",
    "eslint": "9.39.4",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "jest-junit": "17.0.0",
    "neostandard": "0.12.2",
    "nodemon": "3.0.1"
  },
  "overrides": {
    "@opentelemetry/propagator-jaeger": "2.9.0",
    "uuid": "11.1.1"
  },
  "nodemonConfig": {
    "ignore": [
      "**/test-output/**"
    ]
  }
}
